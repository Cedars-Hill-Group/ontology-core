# Configuration file for ontology-core
# Copy this file to config.yaml and update the paths for your environment.
# config.yaml is excluded from version control (.gitignore) to protect local paths.

knowledge_base:
  # Absolute or relative path to the root directory that contains the
  # markdown files for people, companies, and properties.
  path: "/path/to/your/knowledge-base"

  # Optional subdirectory names within the knowledge_base path.
  # Defaults shown below — override only if your structure differs.
  companies_dir: "companies"
  people_dir: "people"
  properties_dir: "properties"

output:
  # Directory where generated JSON artefacts are written.
  path: "output"
